@startuml Flujo_Internacion_Secuencia

!theme plain
skinparam backgroundColor #FEFEFE
skinparam handwritten false

skinparam participant {
    BackgroundColor<<actor>> #FFE0B2
    BackgroundColor<<controller>> #E3F2FD
    BackgroundColor<<service>> #E8F5E9
    BackgroundColor<<model>> #F3E5F5
}

title Secuencia - Flujo de Internación: Ingreso hasta Alta

actor "Paciente" as PAC
actor "Recepcionista" as REC
actor "Médico" as MED
actor "Cajero" as CAJ

participant "HospitalizacionController\n(Reception)" as HOSPC <<controller>>
participant "CuentaCobroService" as CCS <<service>>
participant "AsignacionCamaService" as ACS <<service>>
participant "Hospitalizacion\n(Model)" as HOSPM <<model>>
participant "CuentaCobro\n(Model)" as CCM <<model>>
participant "CajaOperativaController" as CAC <<controller>>
participant "AplicarSeguroService" as ASS <<service>>

== FASE 1: Ingreso y Registro ==

PAC -> REC : Llega a recepción
REC -> REC : Buscar paciente por CI

alt Paciente no existe
    REC -> HOSPCM : crearOActualizarPaciente()
    HOSPCM -> HOSPCM : Crear paciente con seguro default
else Paciente existe
    REC -> HOSPCM : Actualizar datos si es necesario
end

REC -> HOSPCM : registrarHospitalizacion()
HOSPCM -> HOSPCM : Verificar hospitalización activa
HOSPCM -> HOSPCM : Crear triage amarillo
HOSPCM -> HOSPCM : Generar ID: HOSP-{timestamp}

== FASE 2: Creación de Cuenta Maestra ==

HOSPCM -> CCS : obtenerOCrearCuentaMaestra(ci, 'internacion', seguro_id)

alt Cuenta post-pago activa existe
    CCS -> CCM : Buscar cuenta pendiente/parcial
    CCM --> CCS : Cuenta existente
    CCS -> CCS : Reutilizar cuenta
else No existe cuenta activa
    CCS -> CCM : Crear nueva cuenta
    note right
        ID: CC-{YmdHis}-{random}
        Estado: pendiente
        es_post_pago: true
    end note
    CCM --> CCS : Cuenta creada
end

CCS --> HOSPCM : Cuenta maestra

HOSPCM -> CCS : agregarCargoConDeduplicacion()
CCS -> CCM : Agregar detalle: Admisión Internación
CCS -> CCS : Verificar duplicados por origen

alt Seguro aplicable
    CCS -> CCM : seguro_estado = pendiente_autorizacion
end

HOSPCM -> REC : Hospitalización registrada
REC -> PAC : Entregar comprobante

== FASE 3: Asignación de Habitación ==

REC -> ACS : asignar(habitacion, cama_id, hospitalizacion_id)
ACS -> HOSPM : Obtener hospitalización
ACS -> CCM : obtenerOCrearCuenta()

alt Cama disponible
    ACS -> HOSPM : Actualizar habitacion_id, cama_id
    ACS -> CCM : Crear detalle de estadía
    note right
        Tipo: estadia
        Descripción: Estancia Internación
        Precio/día: según cama
    end note
    ACS -> ACS : Marcar cama ocupada
    ACS --> REC : Asignación exitosa
else Cama no disponible
    ACS --> REC : Error: Cama ocupada
end

== FASE 4: Atención Médica ==

PAC -> MED : Recibe atención diaria

loop Evoluciones médicas
    MED -> HOSPM : guardarEvolucion()
    
    alt Agregar medicamentos
        HOSPM -> HOSPM : Validar stock
        HOSPM -> HOSPM : Descontar del almacén
        HOSPM -> CCS : Agregar cargo medicamento
        CCS -> CCM : Crear detalle cuenta
    end
    
    alt Agregar equipos médicos
        MED -> HOSPM : Definir equipo/precio
        HOSPM -> CCS : Agregar cargo equipo_medico
        CCS -> CCM : Crear detalle cuenta
    end
    
    HOSPM -> HOSPM : Guardar historial en equipos_medicos (JSON)
end

== FASE 5: Alta Médica ==

MED -> REC : Solicitar alta del paciente
REC -> HOSPCM : darAlta(hospitalizacion_id)
HOSPCM -> HOSPM : Actualizar fecha_alta, motivo_alta

note right of ACS
  LiberacionCamaService
end note

HOSPCM -> ACS : liberar(cama)
ACS -> HOSPM : Calcular días estancia
note right
  Fórmula: max(1, diffInDays + 1)
end note
ACS -> CCM : Actualizar detalle estadía
CCM -> CCM : cantidad = días reales
CCM -> CCM : subtotal = días × precio/día

ACS -> HOSPM : Guardar total_estancia
ACS -> ACS : Liberar cama (disponible)
ACS -> REC : Cama liberada

== FASE 6: Cobro en Caja ==

PAC -> CAJ : Se presenta a pagar
CAJ -> CAC : Abrir caja (si es necesario)

loop Pagos hasta completar
    CAJ -> CAC : getDetalleCuenta(cuenta_id)
    CAC -> CCM : Cargar cuenta con detalles
    CCM --> CAC : Datos de cuenta
    
    CAC -> ASS : aplicarSiCorresponde(cuenta)
    
    alt Seguro aplica
        ASS -> CCM : Aplicar cobertura
        CCM -> CCM : seguro_estado = autorizado
        CCM -> CCM : Calcular montos cubierto/paciente
    end
    
    CAC --> CAJ : Mostrar resumen
    note right
      Total: Bs. X
      Cubierto seguro: Bs. Y
      A pagar: Bs. Z
    end note
    
    CAJ -> CAJ : Seleccionar método de pago
    CAJ -> CAC : procesarCobro(monto, metodo)
    
    CAC -> CCM : registrarPago()
    CCM -> CCM : total_pagado += monto
    CCM -> CCM : recalcularTotales()
    
    alt Saldo <= 0
        CCM -> CCM : estado = pagado
    else
        CCM -> CCM : estado = parcial
    end
    
    CAC -> CAJ : Comprobante generado
end

CAJ -> PAC : Entregar factura/comprobante
PAC -> REC : Sale de la clínica

@enduml
